<Window x:Class="DockBar.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DockBar"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        AllowDrop="True"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Background="Transparent"
        Visibility="Collapsed">
    <Border x:Name="Root"
            Background="Transparent"
            CornerRadius="12"
            Padding="10">
        <DockPanel x:Name="Panel" LastChildFill="True">
            <!-- 分类标签:横向 WrapPanel,超出自动换行;不要竖排 -->
            <ItemsControl x:Name="Tabs" DockPanel.Dock="Top" Margin="0,0,0,8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ThinScrollViewer}">
                <ItemsControl x:Name="Items">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
