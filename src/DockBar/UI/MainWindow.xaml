<Window x:Class="DockBar.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DockBar"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        AllowDrop="True"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Background="#1F1F1F"
        Visibility="Collapsed">
    <!--
        AllowsTransparency 已经去掉 = 不再用 WPF Layered Window。
        原因:开 AllowsTransparency=True + 亚克力时,WPF 的 OLE 命中测试在透明像素上不可靠,
        窗口里拖图标会漏到下层桌面 HWND 直接被桌面接走 → 文件被搬到桌面。
        换成实心 Background 后 OLE 拖拽路径稳定,图标排序 / 跨分类 / 拖出窗口的边界判定都精确。
        圆角由 DWM 系统级 corner preference 提供(MainWindow.xaml.cs ApplyTheme),不再 WPF 画。
    -->
    <!-- AllowDrop 顺着可视树一路开,确保鼠标无论落在 Border/DockPanel/Tabs/ScrollViewer/Items/WrapPanel
         哪一层,WPF 都能找到 OLE drop target,顶层 PreviewDrag* 才能触发。
         漏掉任何一层都会出现「拖到这片区域光标变禁止符」的死角。 -->
    <Border x:Name="Root"
            Background="Transparent"
            CornerRadius="0"
            Padding="14,12,14,12"
            AllowDrop="True">
        <DockPanel x:Name="Panel" LastChildFill="True" AllowDrop="True">
            <!-- 分类标签:横向 WrapPanel,超出自动换行;不要竖排。下方一根细分割线把标签和图标区分开。 -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="{DynamicResource Stroke}"
                    BorderThickness="0,0,0,1"
                    Margin="0,0,0,10"
                    Padding="0,0,0,8"
                    AllowDrop="True">
                <ItemsControl x:Name="Tabs" AllowDrop="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ThinScrollViewer}"
                          AllowDrop="True"
                          Padding="0,2,0,2">
                <ItemsControl x:Name="Items" AllowDrop="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel AllowDrop="True"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
