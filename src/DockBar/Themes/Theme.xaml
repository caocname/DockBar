<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 颜色:Win11 暗色系 ===== -->
    <!--
        历史:旧版主窗口走亚克力,要求纯透明 brush 由系统合成画底。
        现在主窗口改成实色背景(为了 OLE 拖放可靠) + DWM 圆角。这两个 brush 仅
        InputBoxWindow / SettingsWindow / IconPickerWindow / TriggerWindow 还在用,
        这些窗口仍走亚克力,所以保持透明。
    -->
    <SolidColorBrush x:Key="AcrylicTint"      Color="#00000000"/>
    <SolidColorBrush x:Key="AcrylicTintLight" Color="#00FFFFFF"/>

    <!-- 对话框(设置/管理图标/输入框)用的实色卡片底,确保任何桌面背景下文字都可读 -->
    <SolidColorBrush x:Key="DialogSurfaceDark"  Color="#F22A2A2A"/>
    <SolidColorBrush x:Key="DialogSurfaceLight" Color="#F2F5F5F5"/>

    <SolidColorBrush x:Key="Surface"          Color="#E61F1F1F"/>
    <SolidColorBrush x:Key="SurfaceTrigger"   Color="#80606060"/>
    <!-- hover 调亮一点,实色背景下太淡看不出 -->
    <SolidColorBrush x:Key="SurfaceHover"     Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="SurfaceHoverLight" Color="#14000000"/>
    <SolidColorBrush x:Key="SurfacePress"     Color="#33FFFFFF"/>

    <!-- 暗色主题文字 -->
    <SolidColorBrush x:Key="Foreground"       Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ForegroundDim"    Color="#B3FFFFFF"/>
    <SolidColorBrush x:Key="ForegroundFaint"  Color="#66FFFFFF"/>
    <!-- 浅色主题文字 -->
    <SolidColorBrush x:Key="ForegroundLight"     Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="ForegroundDimLight"  Color="#A0000000"/>

    <SolidColorBrush x:Key="Accent"           Color="#FF60CDFF"/>
    <SolidColorBrush x:Key="ItemHover"        Color="#1FFFFFFF"/>
    <!-- 描边:实色窗口下提一点,让卡片 hover/分割线看得出来 -->
    <SolidColorBrush x:Key="Stroke"           Color="#33FFFFFF"/>

    <!-- ===== 分类标签按钮 =====
         Foreground / Hover 用 DynamicResource:对话框可在 Window.Resources 里覆盖
         ForegroundDim/Foreground/SurfaceHover 切到浅色版本,而不需要重写 Style。 -->
    <Style x:Key="TabButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundDim}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- 选中态下方小圆点 -->
                        <Rectangle x:Name="Indicator" Fill="{DynamicResource Accent}"
                                   Height="2" Width="18" RadiusX="1" RadiusY="1"
                                   VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                   Margin="0,0,0,-2" Visibility="Collapsed"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHover}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
                            <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 圆角无边框按钮 ===== -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundDim}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHover}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfacePress}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 主操作按钮 ===== -->
    <Style x:Key="AccentButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Accent}"/>
        <Setter Property="Foreground" Value="#FF111111"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 文本框:Foreground 不写死,继承 -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="#22000000"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Foreground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== CheckBox / RadioButton:不写死前景色,继承所在窗口的 Foreground -->
    <Style TargetType="CheckBox">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ===== 默认 Button(setting 等地方未指定 style 的) ===== -->
    <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}"/>

    <!-- ===== 极细滚动条 ===== -->
    <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="MinWidth" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border x:Name="ThumbBd"
                                                    Background="#44FFFFFF"
                                                    CornerRadius="3"
                                                    Margin="1,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#88FFFFFF"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter Grid.Column="0"/>
                        <ScrollBar Grid.Column="1" Name="PART_VerticalScrollBar"
                                   Style="{StaticResource ThinScrollBar}"
                                   Orientation="Vertical"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== ContextMenu (我们自己用的菜单,与 Shell 原生菜单不冲突) ===== -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

</ResourceDictionary>
